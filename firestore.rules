rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// Règles Firestore durcies — Calendrier 3T TECH
//
// ⚠️ LIMITE IMPORTANTE : l'app n'utilise PAS Firebase Auth (le login Google ne
// sert qu'à Google Drive). Sans identité côté base, on NE PEUT PAS restreindre
// la lecture ni réserver l'écriture/suppression au propriétaire. Ces règles
// apportent donc une défense « en profondeur » :
//   • validation de TYPE et de TAILLE des champs (anti-spam, anti-payload géant) ;
//   • blocage des collections inconnues (deny par défaut) ;
//   • pas de documents anormalement gros.
// Le compte de service (cron GitHub + Worker Cloudflare) utilise l'Admin SDK qui
// CONTOURNE ces règles → les notifs/STOP/notified continuent de marcher.
//
// 🔒 Pour une vraie étanchéité (réserver l'écriture aux régisseurs identifiés),
//    il faut ajouter Firebase Auth (connexion Google) puis exiger request.auth.
//    Voir BACKLOG.md (sécurité).
//
// À publier : Console Firebase → Firestore Database → Règles → Publier.
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    function str(v, n) { return v is string && v.size() <= n; }
    function optStr(d, k, n) { return !(k in d) || str(d[k], n); }
    function smallList(v, n) { return v is list && v.size() <= n; }

    // Jetons push : 1 doc par appareil (id = 3t_device_id ou jeton FCM).
    match /pushTokens/{id} {
      allow read: if true;
      allow delete: if true;
      allow create, update: if str(request.resource.data.token, 4096)
        && optStr(request.resource.data, 'platform', 40)
        && optStr(request.resource.data, 'reg', 80);
    }

    // Planning à venir publié par l'app pour le cron (données du planning, non sensibles).
    match /schedule/{id} {
      allow read: if true;
      allow create, update: if request.resource.data.days is list
        && request.resource.data.days.size() <= 400
        && optStr(request.resource.data, 'by', 80);
    }

    // Formations proposées par les régisseurs.
    match /formations/{id} {
      allow read: if true;
      allow delete: if true;
      allow create, update: if str(request.resource.data.subject, 200)
        && str(request.resource.data.date, 20)
        && str(request.resource.data.by, 80)
        && optStr(request.resource.data, 'time', 10)
        && smallList(request.resource.data.participants, 60);
    }

    // Créneaux de réunion (Framadate maison).
    match /meetingSlots/{id} {
      allow read: if true;
      allow delete: if true;
      allow create, update: if str(request.resource.data.date, 20)
        && str(request.resource.data.by, 80)
        && optStr(request.resource.data, 'time', 10)
        && smallList(request.resource.data.available, 60);
    }

    // Notes partagées.
    match /notes/{id} {
      allow read: if true;
      allow delete: if true;
      allow create, update: if str(request.resource.data.text, 2000)
        && str(request.resource.data.by, 80);
    }

    // Profils (1 doc par email). La lecture reste ouverte (l'app lit par email sans
    // être authentifiée côté base) → les emails restent lisibles tant qu'il n'y a
    // pas de Firebase Auth.
    match /profiles/{email} {
      allow read: if true;
      allow create, update: if str(request.resource.data.email, 200)
        && optStr(request.resource.data, 'reg', 80)
        && optStr(request.resource.data, 'emoji', 16)
        && optStr(request.resource.data, 'anniv', 12)
        && optStr(request.resource.data, 'name', 120);
    }

    // sentLog / stops : écrits UNIQUEMENT par le compte de service (Admin SDK,
    // qui contourne les règles). Côté client : lecture seule, aucune écriture.
    match /sentLog/{id} { allow read: if true; allow write: if false; }
    match /stops/{id}   { allow read: if true; allow write: if false; }

    // Tout le reste : refusé.
    match /{document=**} { allow read, write: if false; }
  }
}
