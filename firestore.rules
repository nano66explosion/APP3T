rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// Règles Firestore — Calendrier 3T TECH (PHASE 2 : authentification requise)
//
// L'app ouvre une session Firebase Auth (custom token signé par le Worker à partir
// du login Google — voir BACKLOG « Sécurité »). Toute lecture/écriture côté client
// exige désormais `request.auth != null` → l'accès anonyme / REST direct est bloqué,
// et les emails de `profiles` ne sont plus lisibles publiquement.
//
// Le compte de service (cron GitHub + Worker Cloudflare) utilise un jeton de service
// (Admin/OAuth cloud-platform) qui CONTOURNE ces règles → notifs/STOP/notified/
// lecture pushTokens continuent de marcher.
//
// En plus de l'auth : validation de TYPE/TAILLE des champs, collections inconnues
// refusées.  À publier : Console Firebase → Firestore Database → Règles → Publier.
//
// 🔧 Option (non activée) : restreindre l'écriture aux régisseurs via une allowlist
//    d'emails — `request.auth.token.email` est dispo (claim du custom token).
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    function authed() { return request.auth != null; }
    function str(v, n) { return v is string && v.size() <= n; }
    function optStr(d, k, n) { return !(k in d) || str(d[k], n); }
    function smallList(v, n) { return v is list && v.size() <= n; }

    // Jetons push : 1 doc par appareil (id = 3t_device_id ou jeton FCM).
    match /pushTokens/{id} {
      allow read, delete: if authed();
      allow create, update: if authed()
        && str(request.resource.data.token, 4096)
        && optStr(request.resource.data, 'platform', 40)
        && optStr(request.resource.data, 'reg', 80);
    }

    // Planning à venir publié par l'app pour le cron.
    match /schedule/{id} {
      allow read: if authed();
      allow create, update: if authed()
        && request.resource.data.days is list
        && request.resource.data.days.size() <= 400
        && optStr(request.resource.data, 'by', 80);
    }

    // Formations proposées par les régisseurs.
    match /formations/{id} {
      allow read, delete: if authed();
      allow create, update: if authed()
        && str(request.resource.data.subject, 200)
        && str(request.resource.data.date, 20)
        && str(request.resource.data.by, 80)
        && optStr(request.resource.data, 'time', 10)
        && smallList(request.resource.data.participants, 60);
    }

    // Créneaux de réunion (Framadate maison).
    match /meetingSlots/{id} {
      allow read, delete: if authed();
      allow create, update: if authed()
        && str(request.resource.data.date, 20)
        && str(request.resource.data.by, 80)
        && optStr(request.resource.data, 'time', 10)
        && smallList(request.resource.data.available, 60);
    }

    // Notes partagées.
    match /notes/{id} {
      allow read, delete: if authed();
      allow create, update: if authed()
        && str(request.resource.data.text, 2000)
        && str(request.resource.data.by, 80);
    }

    // Profils (1 doc par email) — lecture réservée aux utilisateurs authentifiés.
    match /profiles/{email} {
      allow read: if authed();
      allow create, update: if authed()
        && str(request.resource.data.email, 200)
        && optStr(request.resource.data, 'reg', 80)
        && optStr(request.resource.data, 'emoji', 16)
        && optStr(request.resource.data, 'anniv', 12)
        && optStr(request.resource.data, 'name', 120);
    }

    // sentLog / stops : écrits UNIQUEMENT par le compte de service (qui contourne
    // les règles). Côté client : lecture seule (authentifié), aucune écriture.
    match /sentLog/{id} { allow read: if authed(); allow write: if false; }
    match /stops/{id}   { allow read: if authed(); allow write: if false; }

    // Tout le reste : refusé.
    match /{document=**} { allow read, write: if false; }
  }
}
